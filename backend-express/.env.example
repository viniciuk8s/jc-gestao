# Copie para .env e preencha.

# Connect > "Session pooler" do Supabase (IPv4 / Render). Troque SENHA, <ref> e <reg>.
DATABASE_URL=postgresql://postgres.SEU-REF:SENHA@aws-0-SUA-REGIAO.pooler.supabase.com:5432/postgres

# URL do projeto (valida o login via JWKS).
SUPABASE_URL=https://SEU-REF.supabase.co

# Só para projetos antigos (HS256). Projeto novo deixa em branco.
SUPABASE_JWT_SECRET=

# Domínio do front na Vercel. Várias separadas por vírgula. "*" só em dev.
ALLOWED_ORIGINS=https://seu-projeto.vercel.app

# Porta (o Render injeta automaticamente).
PORT=8000
